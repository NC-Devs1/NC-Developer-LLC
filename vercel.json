{
  "version": 2,
  "routes": [
    { "src": "/api/chat",          "dest": "/api/chat.js" },
    { "src": "/api/review-submit", "dest": "/api/review-submit.js" },
    { "src": "/api/review-action", "dest": "/api/review-action.js" },
    { "src": "/brand_assets/(.*)", "dest": "/brand_assets/$1" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.js)",   "dest": "/$1" },
    { "src": "/(.*\\.png)",  "dest": "/$1" },
    { "src": "/(.*\\.pdf)",  "dest": "/$1" },
    { "src": "/(.*)",        "dest": "/$1" }
  ]
}
