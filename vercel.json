{
  "version": 2,
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/brand_assets/(.*)", "dest": "/brand_assets/$1" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.png)",  "dest": "/$1" },
    { "src": "/(.*\\.pdf)",  "dest": "/$1" },
    { "src": "/(.*)",        "dest": "/$1" }
  ]
}
